DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/icp_finder
REDIS_URL=redis://localhost:6379/0

# LLM keys (at least one required for extraction)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Crawler API keys
GOOGLE_PLACES_API_KEY=
YELP_FUSION_API_KEY=
SERPAPI_API_KEY=

PROXY_LIST=

# Security (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=
API_KEY=

# CORS — comma-separated allowed origins (debug=true allows all)
ALLOWED_ORIGINS=https://n4cluster.com,https://www.n4cluster.com

# Dashboard login (if password is empty, dashboard is open access)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

LOG_LEVEL=INFO
SCORING_VERSION=1

# SendGrid — Lead Communication Tracking (Phase 1)
SENDGRID_API_KEY=SG.
SENDGRID_FROM_EMAIL=outreach@yourdomain.com
SENDGRID_FROM_NAME=N4Cluster
SENDGRID_WEBHOOK_SIGNING_KEY=

# Email click/open tracking
# Set to http://localhost:8000 for local development
TRACKING_BASE_URL=http://localhost:8000
TRACKING_FALLBACK_URL=https://n4cluster.com
